# GEMINI_API_KEY: Required for the /api/parse-resume route to call the Gemini API.
# Copy this file to .env.local and fill in your key.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Supabase project credentials (Project Settings -> API Keys in the Supabase dashboard).
NEXT_PUBLIC_SUPABASE_URL="MY_SUPABASE_URL"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="MY_SUPABASE_PUBLISHABLE_KEY"

# Secret key: server-only, bypasses Row Level Security. Never expose this to
# the browser or prefix it with NEXT_PUBLIC_. Used by scripts/seed.ts.
SUPABASE_SECRET_KEY="MY_SUPABASE_SECRET_KEY"
