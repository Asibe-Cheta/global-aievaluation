# GEMINI_API_KEY: Required for the /api/parse-resume route to call the Gemini API.
# Copy this file to .env.local and fill in your key.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Supabase project credentials (Project Settings -> API Keys in the Supabase dashboard).
NEXT_PUBLIC_SUPABASE_URL="MY_SUPABASE_URL"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="MY_SUPABASE_PUBLISHABLE_KEY"

# Secret key: server-only, bypasses Row Level Security. Never expose this to
# the browser or prefix it with NEXT_PUBLIC_. Used by scripts/seed.ts and the
# Stripe webhook (lib/supabase/service.ts).
SUPABASE_SECRET_KEY="MY_SUPABASE_SECRET_KEY"

# Stripe (Dashboard -> Developers -> API keys / Webhooks). Test-mode keys
# while developing. Create one Product per paid tier (Professional, Career
# Accelerator) each with a monthly and an annual recurring Price, and paste
# the four Price IDs below. The webhook secret comes from either the
# Dashboard's webhook endpoint (pointed at /api/stripe/webhook) or
# `stripe listen --forward-to localhost:3000/api/stripe/webhook` locally.
STRIPE_SECRET_KEY="MY_STRIPE_SECRET_KEY"
STRIPE_WEBHOOK_SECRET="MY_STRIPE_WEBHOOK_SECRET"
STRIPE_PRICE_PROFESSIONAL_MONTHLY="MY_STRIPE_PRICE_ID"
STRIPE_PRICE_PROFESSIONAL_ANNUAL="MY_STRIPE_PRICE_ID"
STRIPE_PRICE_ACCELERATOR_MONTHLY="MY_STRIPE_PRICE_ID"
STRIPE_PRICE_ACCELERATOR_ANNUAL="MY_STRIPE_PRICE_ID"
